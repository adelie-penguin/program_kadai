#**************************************************
# 「cuda01.cu」をコンパイルしたいときに使うmakefile
#
#--------------------------------------------
#  ・ファイル名の設定は10行目の「SRC=」
#  ・コンパイルオプションは15行目の「CFLAG+=」
#  ・16行目以降の「#」を消すとコンパイルオプションを追加
#**************************************************

SRC  = cuda01
CFLAG=

#--[ コンパイルオプションの設定 ]-----------------------

CFLAG += -lm -O3
#CFLAG += -g -G
#CFLAG += -pthread
#CFLAG += -fopenmp

#--[ deviceからprint関数を利用するためのオプション ]----

GFLAG = -arch=native --ptxas-options=-v

#========================

$(SRC) : $(SRC).cu
	nvcc -o $@ $< $(CFLAG) $(GFLAG) 

#========================
# .cu拡張子でカラースキームが働かない場合は.cで編集しても大丈夫
%.cu: %.c
	cp $< $@
